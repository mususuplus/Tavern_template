{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "default": {},
  "type": "object",
  "properties": {
    "主角": {
      "default": {},
      "type": "object",
      "properties": {
        "职业": {
          "default": "普通冒险者",
          "type": "string"
        },
        "信仰": {
          "default": "无",
          "type": "string"
        },
        "当前地点": {
          "default": "中央翡翠平原",
          "type": "string"
        },
        "称号": {
          "default": "流浪的守夜人",
          "type": "string"
        },
        "状态": {
          "default": "健康",
          "type": "string"
        },
        "临时状态": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "状态名"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "类型": {
                "default": "buff",
                "type": "string",
                "enum": [
                  "buff",
                  "debuff"
                ]
              },
              "描述": {
                "type": "string"
              }
            }
          }
        },
        "货币": {
          "default": {},
          "type": "object",
          "properties": {
            "金狮": {
              "type": "number"
            },
            "银辉币": {
              "type": "number"
            },
            "铜叶币": {
              "type": "number"
            },
            "以太结晶": {
              "type": "number"
            }
          }
        },
        "生命": {
          "default": 340,
          "type": "number"
        },
        "生命上限": {
          "default": 450,
          "type": "number"
        },
        "法力": {
          "default": 120,
          "type": "number"
        },
        "法力上限": {
          "default": 200,
          "type": "number"
        },
        "奥法之灾觉醒度": {
          "default": 45,
          "type": "number"
        },
        "奥法之灾觉醒度上限": {
          "default": 100,
          "type": "number"
        },
        "宿主档案": {
          "default": {},
          "type": "object",
          "properties": {
            "阶段代码": {
              "default": "S4",
              "type": "string"
            },
            "阶段名称": {
              "default": "被追踪调查",
              "type": "string"
            },
            "阶段称谓": {
              "default": "前兆潜伏",
              "type": "string"
            },
            "异象前兆": {
              "default": "周围魔力浓度偶尔失衡，器物静电、祷文失准、法阵迟滞是最早的信号。",
              "type": "string"
            },
            "风险提示": {
              "default": "宿主本人可能尚未察觉，但观测者与敏感施法者已经能捕捉到微弱痕迹。",
              "type": "string"
            },
            "下一阈值": {
              "default": "随着剧情推进与情绪压力积累，宿主会被更明确地卷入调查与怀疑。",
              "type": "string"
            },
            "可能代价": {
              "default": "每一次忽视异常，都会让失控的那一步更突然。",
              "type": "string"
            }
          }
        },
        "装备栏": {
          "default": {
            "主手": {},
            "副手": {},
            "服饰": {},
            "饰品": {}
          },
          "type": "object",
          "propertyNames": {
            "type": "string",
            "enum": [
              "主手",
              "副手",
              "服饰",
              "饰品"
            ]
          },
          "additionalProperties": {
            "default": {},
            "type": "object",
            "properties": {
              "装备名": {
                "default": "空置",
                "type": "string"
              },
              "描述": {
                "type": "string"
              },
              "品质": {
                "default": "common",
                "$ref": "#/$defs/__schema0"
              }
            }
          },
          "required": [
            "主手",
            "副手",
            "服饰",
            "饰品"
          ]
        },
        "物品栏": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "物品名"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "描述": {
                "type": "string"
              },
              "数量": {
                "type": "number"
              },
              "品质": {
                "default": "common",
                "$ref": "#/$defs/__schema0"
              }
            },
            "required": [
              "数量"
            ]
          }
        }
      }
    },
    "世界": {
      "default": {},
      "type": "object",
      "properties": {
        "纪元": {
          "default": "暗影纪元",
          "type": "string"
        },
        "月": {
          "default": 1,
          "type": "number"
        },
        "日": {
          "default": 1,
          "type": "number"
        },
        "时段": {
          "default": "上午",
          "type": "string",
          "enum": [
            "清晨",
            "上午",
            "正午",
            "下午",
            "黄昏",
            "深夜"
          ]
        },
        "末日时钟刻度": {
          "default": 3,
          "type": "number"
        },
        "委托等级": {
          "default": "铜牌",
          "type": "string"
        },
        "当前聚焦预言": {
          "default": "魔王",
          "type": "string"
        },
        "当前聚焦说明": {
          "default": "综合地点、时钟与势力活动后，魔王相关卷宗仍是当前最具解释力的焦点。",
          "type": "string"
        },
        "神学回声": {
          "default": "你尚未以某位神祇的语言理解这些征兆，因此档案馆将更依赖地点、势力和危机热度来组织线索。",
          "type": "string"
        },
        "本幕纪要": {
          "type": "string"
        },
        "区域态势": {
          "default": {},
          "type": "object",
          "properties": {
            "主导危机": {
              "default": "帝国腹地的秩序表面稳定，实则被魔潮军情与内部派系角力同时拉扯。",
              "type": "string"
            },
            "推荐关注": {
              "default": "优先关注帝国军政、观测者调令与商路封锁，它们最先暴露大战前兆。",
              "type": "string"
            },
            "典型异象": {
              "default": "白昼仍明亮，但市集消息传播异常迅速，风声往往先于军报抵达。",
              "type": "string"
            },
            "势力拉扯": {
              "default": "帝国希望维持稳定表象，观测者更在意异常数据，远方行歌则盯着任务与利润。",
              "type": "string"
            }
          }
        },
        "情报流": {
          "default": {},
          "type": "object",
          "properties": {
            "地点变化": {
              "default": "档案流正在等待新的世界摘要。",
              "type": "string"
            },
            "势力动作": {
              "default": "各方势力正在重新评估局势。",
              "type": "string"
            },
            "宿主异常": {
              "default": "宿主异动尚未形成公开卷宗。",
              "type": "string"
            },
            "当前任务": {
              "default": "当前没有可追踪的任务情报。",
              "type": "string"
            }
          }
        }
      }
    },
    "小队": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "成员名"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "职业": {
            "type": "string"
          },
          "生命": {
            "type": "number"
          },
          "生命上限": {
            "default": 1,
            "type": "number"
          },
          "状态": {
            "type": "string"
          }
        }
      }
    },
    "人际关系": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "NPC名"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "好感度": {
            "type": "number"
          },
          "关系": {
            "type": "string"
          },
          "描述": {
            "type": "string"
          },
          "态度温度": {
            "default": "谨慎观望",
            "type": "string"
          },
          "立场": {
            "default": "地方侧",
            "type": "string",
            "enum": [
              "帝国侧",
              "观测侧",
              "异端侧",
              "地方侧",
              "同行侧"
            ]
          },
          "阵营牵引": {
            "default": "暂无明确阵营拉扯情报。",
            "type": "string"
          }
        }
      }
    },
    "势力": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "势力名"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "声望": {
            "default": "中立",
            "type": "string",
            "enum": [
              "友善",
              "中立",
              "冷淡",
              "敌对",
              "通缉",
              "崇拜",
              "盟友"
            ]
          },
          "描述": {
            "type": "string"
          }
        }
      }
    },
    "委托列表": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "委托名"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "类型": {
            "default": "支线",
            "type": "string",
            "enum": [
              "主线",
              "支线",
              "每日",
              "临危受命"
            ]
          },
          "说明": {
            "type": "string"
          },
          "目标": {
            "type": "string"
          },
          "奖励": {
            "type": "string"
          },
          "惩罚": {
            "type": "string"
          },
          "状态": {
            "default": "未接取",
            "type": "string",
            "enum": [
              "未接取",
              "进行中",
              "已完成",
              "已失败"
            ]
          },
          "排序权重": {
            "type": "number"
          },
          "危机关联": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "__schema0": {
      "type": "string",
      "enum": [
        "common",
        "rare",
        "epic",
        "legendary"
      ]
    }
  }
}